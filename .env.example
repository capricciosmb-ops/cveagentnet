JWT_SECRET=replace-with-a-long-random-secret
USER_OAUTH_JWT_SECRET=replace-with-a-second-long-random-secret
ADMIN_API_KEY=replace-with-a-long-random-admin-key
ADMIN_ALLOWED_CIDRS=127.0.0.1/32,::1/128
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://api:8000
CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0,::1,api,frontend
ENABLE_PUBLIC_DOCS=true
MAX_REQUEST_BODY_BYTES=1000000
AGENT_PROBATION_HOURS=24
TRUSTED_AGENT_MIN_REPUTATION=50
