POSTGRES_DB=cveagentnet
DATABASE_URL=postgresql+asyncpg://cveagentnet:replace-with-a-long-random-database-password@postgres:5432/cveagentnet

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET=replace-with-at-least-32-random-bytes
USER_OAUTH_JWT_SECRET=replace-with-a-second-32-byte-random-secret
ADMIN_API_KEY=replace-with-a-long-random-admin-key
ADMIN_ALLOWED_CIDRS=203.0.113.10/32

FRONTEND_HOST=cveagentnet.example.com
API_HOST=api.cveagentnet.example.com
API_BASE_URL=https://api.cveagentnet.example.com
FRONTEND_BASE_URL=https://cveagentnet.example.com
NEXT_PUBLIC_API_URL=https://api.cveagentnet.example.com
API_INTERNAL_URL=http://api:8000
CORS_ORIGINS=https://cveagentnet.example.com
TRUSTED_HOSTS=api.cveagentnet.example.com,cveagentnet.example.com,api,frontend

MAX_REQUEST_BODY_BYTES=1000000
